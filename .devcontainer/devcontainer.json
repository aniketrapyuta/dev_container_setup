{
  "name": "Development (Noetic)",
  "dockerComposeFile": [
    "../docker-compose.yaml"
  ],
  "service": "development-noetic",
  "workspaceFolder": "/home/dev/catkin_ws/src",
  "shutdownAction": "none",
  "overrideCommand": true,
  "initializeCommand": "bash ${localWorkspaceFolder}/scripts/init-host.sh",
  "containerEnv": {
    "ROS_DISTRO": "noetic"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-iot.vscode-ros",
        "ms-vscode.cpptools",
        "ms-python.python",
        "ms-azuretools.vscode-docker"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
  "postAttachCommand": "bash -lc 'source /opt/ros/noetic/setup.bash && [ -f /home/dev/catkin_ws/devel/setup.bash ] && source /home/dev/catkin_ws/devel/setup.bash || true'"
}
