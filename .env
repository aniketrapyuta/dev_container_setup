# Private, local-only compose/build overrides
# This file is gitignored via .gitignore -> .private/

BASE_IMAGE=<my_image_name>
DEV_USER=dev
DEV_HOME=/home/dev
HOST_WORKSPACE=/home/<user_name>/my_catkin_ws
IMAGE_NAME=<my_image_name>-noetic:dev
CONTAINER_NAME=<my_container_name>
INSTALL_EXTRA_DEV_TOOLS=true
DOCKER_UID=1000
DOCKER_GID=1000
DISPLAY=:0
HOST_XAUTHORITY=/run/user/1000/.mutter-Xwaylandauth.M9W8N3
